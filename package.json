{
  "name": "monoverse-platform",
  "version": "2.4.0",
  "description": "منصة Monorepo متكاملة - Frontend (Next.js) + Backend (Express.js)",
  "private": true,
  "workspaces": [
    "Frontend Developer",
    "Backend"
  ],
  "scripts": {
    "dev": "cd \"Frontend Developer\" && ../node_modules/.bin/next dev -p 3000",
    "dev:backend": "cd Backend && node src/server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "build": "cd \"Frontend Developer\" && ../node_modules/.bin/next build",
    "start": "cd \"Frontend Developer\" && ../node_modules/.bin/next start -p 3000",
    "lint": "cd \"Frontend Developer\" && ../node_modules/.bin/eslint .",
    "install:all": "npm install --workspaces"
  },
  "keywords": [
    "monorepo",
    "frontend",
    "backend",
    "nextjs",
    "express",
    "react",
    "typescript",
    "tailwindcss"
  ],
  "author": "Frontend Developer",
  "license": "MIT"
}
